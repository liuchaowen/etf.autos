# GitHub OAuth 配置（用于登录同步功能）
# 请在 GitHub 创建 OAuth App 后填写以下值
# 创建步骤：GitHub → Settings → Developer settings → OAuth Apps → New OAuth App

# GitHub OAuth App Client ID（公开，前端使用）
GITHUB_CLIENT_ID=your_github_client_id_here

# GitHub OAuth App Client Secret（保密，仅服务端使用）
# 注意：此变量不要暴露到前端，只在 Vercel 服务端使用
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# 回调 URL 设置：
# Authorization callback URL: https://your-domain.vercel.app/auth/callback